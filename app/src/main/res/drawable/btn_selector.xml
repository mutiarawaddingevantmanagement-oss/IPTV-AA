<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state: Cobalt Blue border with solid Navy background -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#1A73E8" />
            <corners android:radius="8dp" />
            <stroke android:width="3dp" android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Pressed state: Thicker Border and darker blue -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1557B0" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Default state: Dark grey with a subtle border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#252525" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#444444" />
        </shape>
    </item>
</selector>
