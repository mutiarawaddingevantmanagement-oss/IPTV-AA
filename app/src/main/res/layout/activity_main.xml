<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Landing Screen (Main IPTV Dashboard) -->
    <LinearLayout
        android:id="@+id/layout_landing"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="visible">

        <!-- Top Header Panel -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_app_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAVEL IPTV ENTERPRISE"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/text_app_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enterprise High-Performance TV Navigator"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <!-- Right Header Controls Pane -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Status Indicator -->
                <TextView
                    android:id="@+id/tv_active_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#1557B0"
                    android:paddingLeft="12dp"
                    android:paddingTop="6dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="6dp"
                    android:text="Default Playlist Active"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="11sp" />

                <!-- Settings Button -->
                <Button
                    android:id="@+id/btn_open_settings"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginLeft="10dp"
                    android:background="@drawable/btn_selector"
                    android:text="⚙️ SETTINGS"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:nextFocusDown="@+id/edit_search_channel" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Playlist Picker & Custom URL Rows (Hidden on Main Menu, Configured via Settings Panel) -->
        <LinearLayout
            android:id="@+id/layout_playlist_picker_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1A1A"
            android:padding="8dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <!-- Custom URL Input -->
            <EditText
                android:id="@+id/edit_m3u_url"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="#2E2E2E"
                android:hint="Enter remote M3U URL..."
                android:textColorHint="#666666"
                android:textColor="#FFFFFF"
                android:paddingLeft="12dp"
                android:textSize="12sp"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:focusable="true"
                android:nextFocusRight="@+id/btn_load_custom"
                android:nextFocusDown="@+id/edit_search_channel"/>

            <Button
                android:id="@+id/btn_load_custom"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginLeft="6dp"
                android:background="@drawable/btn_selector"
                android:text="LOAD LINK"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:focusable="true"
                android:nextFocusLeft="@+id/edit_m3u_url"
                android:nextFocusRight="@+id/btn_upload_file"
                android:nextFocusDown="@+id/edit_search_channel"/>

            <!-- Separator -->
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#333333"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp" />

            <!-- Local file upload button -->
            <Button
                android:id="@+id/btn_upload_file"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/btn_selector"
                android:text="📁 UPLOAD/OPEN FILE"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:focusable="true"
                android:nextFocusLeft="@+id/btn_load_custom"
                android:nextFocusDown="@+id/edit_search_channel"/>
        </LinearLayout>

        <!-- Sub-Header/Search row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT STATION GROUP"
                android:textColor="#888888"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_weight="0" />

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <!-- Interactive Search box -->
            <EditText
                android:id="@+id/edit_search_channel"
                android:layout_width="280dp"
                android:layout_height="36dp"
                android:background="#1F1F1F"
                android:hint="🔍  Search stations..."
                android:textColorHint="#666666"
                android:textColor="#FFFFFF"
                android:paddingLeft="12dp"
                android:textSize="12sp"
                android:singleLine="true"
                android:focusable="true"
                android:nextFocusUp="@+id/btn_open_settings"
                android:nextFocusLeft="@+id/list_categories"
                android:nextFocusDown="@+id/list_channels" />
        </LinearLayout>

        <!-- Main Dynamic TV Board Pane Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Category/Group Selection Pane (Left Pane) -->
            <ListView
                android:id="@+id/list_categories"
                android:layout_width="160dp"
                android:layout_height="match_parent"
                android:background="#161616"
                android:padding="4dp"
                android:scrollbars="vertical"
                android:choiceMode="singleChoice"
                android:divider="#222222"
                android:dividerHeight="1dp"
                android:focusable="true"
                android:nextFocusUp="@+id/edit_search_channel"
                android:nextFocusDown="@+id/list_categories"
                android:nextFocusLeft="@+id/list_categories"
                android:nextFocusRight="@+id/layout_tv_keyboard" />

            <!-- Remote-Friendly Keyboard Panel (Middle Pane) -->
            <LinearLayout
                android:id="@+id/layout_tv_keyboard"
                android:layout_width="265dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#181818"
                android:padding="6dp"
                android:layout_marginLeft="8dp" />

            <!-- Channels Listing Pane (Right Pane) -->
            <ListView
                android:id="@+id/list_channels"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#1a1a1a"
                android:padding="4dp"
                android:scrollbars="vertical"
                android:divider="#222222"
                android:dividerHeight="1dp"
                android:layout_marginLeft="8dp"
                android:focusable="true"
                android:nextFocusUp="@+id/edit_search_channel"
                android:nextFocusDown="@+id/list_channels"
                android:nextFocusLeft="@+id/layout_tv_keyboard"
                android:nextFocusRight="@+id/list_channels" />
        </LinearLayout>

        <!-- Footer Bar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="Pavel IPTV Enterprise © 2026 • High Performance Media Stream Terminal"
            android:textColor="#444444"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Full screen WebView overlay -->
    <android.webkit.WebView
        android:id="@+id/webview_iptv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#121212" />

    <!-- Indeterminate Loading Screen Overlay -->
    <RelativeLayout
        android:id="@+id/layout_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121212"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:indeterminate="true"
                android:indeterminateTint="#00E5FF"
                android:indeterminateTintMode="src_atop" />

            <TextView
                android:id="@+id/tv_loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="LOADING DATA..."
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tv_loading_subtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Optimizing channel buffer handshake"
                android:textColor="#666666"
                android:textSize="11sp"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Error/Offline screen layout overlay -->
    <LinearLayout
        android:id="@+id/layout_offline"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#121212"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No Internet Connection"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Please check your Wi-Fi or Ethernet connection.\nThe gateway will automatically reconnect when a network is detected."
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="180dp"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/btn_selector"
            android:text="RETRY CONNECT"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true" />
    </LinearLayout>

    <!-- Settings Screen Overlay -->
    <LinearLayout
        android:id="@+id/layout_settings"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FA121212"
        android:padding="32dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ PAWEL IPTV SETTINGS"
            android:textColor="#00E5FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Left column: Settings Forms -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3"
                android:orientation="vertical">

                <!-- 1. Change Playlist URL Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEFAULT REMOTE M3U PLAYLIST URL"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <EditText
                        android:id="@+id/settings_playlist_url"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="#1E1E1E"
                        android:hint="Enter remote M3U URL (e.g., https://example.com/live.m3u)..."
                        android:textColorHint="#555555"
                        android:textColor="#FFFFFF"
                        android:paddingLeft="12dp"
                        android:textSize="13sp"
                        android:singleLine="true"
                        android:imeOptions="actionDone"
                        android:focusable="true"/>

                    <Button
                        android:id="@+id/btn_settings_save_playlist"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginLeft="8dp"
                        android:background="@drawable/btn_selector"
                        android:text="SAVE &amp; RELOAD"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:focusable="true" />
                </LinearLayout>

                <!-- 2. Player Buffer Settings -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLAYER BUFFER ENGINE PROFILE"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <RadioGroup
                    android:id="@+id/settings_buffer_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <RadioButton
                        android:id="@+id/radio_buffer_low"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Low Latency (5s Segment)"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:buttonTint="#00E5FF"
                        android:layout_marginRight="16dp"
                        android:focusable="true"/>

                    <RadioButton
                        android:id="@+id/radio_buffer_std"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Standard (10s Reliable)"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:buttonTint="#00E5FF"
                        android:layout_marginRight="16dp"
                        android:focusable="true"/>

                    <RadioButton
                        android:id="@+id/radio_buffer_safe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Legacy/Safe Buffer (25s High Recovery)"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:buttonTint="#00E5FF"
                        android:focusable="true"/>
                </RadioGroup>

                <!-- 3. Clear Cache Actions -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STORAGE &amp; HARDWARE MAINTENANCE"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_settings_clear_cache"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginRight="12dp"
                        android:background="@drawable/btn_selector"
                        android:text="⚡ CLEAR WEB VIEW CACHE &amp; MEMORY"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:focusable="true" />

                    <Button
                        android:id="@+id/btn_settings_reset_db"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:background="@drawable/btn_selector"
                        android:text="🔄 RESET CACHED CHANNELS DATABASE"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:focusable="true" />
                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#333333"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp" />

            <!-- Right column: About Box -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.5"
                android:orientation="vertical"
                android:background="#151515"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT SYSTEM"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/settings_app_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAVEL IPTV v3.0.0"
                    android:textColor="#00E5FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="An Enterprise Ultra Low-Overhead Digital Stream Terminal for Android TV, set-top boxes, and high-DPI environments. Loaded with automated memory recycle keep-alive, SQLite transaction storage, optimized Chromium rendering threads, and real-time network fault detection."
                    android:textColor="#B0BEC5"
                    android:textSize="11sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Bottom Row: Return / Cancel Buttons -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btn_settings_close"
                android:layout_width="160dp"
                android:layout_height="48dp"
                android:layout_alignParentRight="true"
                android:background="@drawable/btn_selector"
                android:text="CLOSE &amp; EXIT"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:focusable="true" />
        </RelativeLayout>

    </LinearLayout>

</FrameLayout>
